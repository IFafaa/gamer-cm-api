  "query": "\n                SELECT t.id, t.community_id, t.enabled, t.name, t.created_at, t.updated_at \n                FROM teams t \n                INNER JOIN party_teams pt ON pt.team_id = t.id \n                WHERE pt.party_id = $1 AND t.enabled = true\n                ",
